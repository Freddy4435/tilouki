# =============================================================================
# Tilouki — Variables PRODUCTION (test local du garde-fou)
# Copier vers .env.production.local — ne jamais committer.
#
# Usage :
#   cp .env.production.local.example .env.production.local
#   # renseigner les valeurs (mêmes noms que Vercel → Environment → Production)
#   npm run verify:deploy:prod
#
# Sur Vercel, configurez les mêmes clés dans Project → Settings → Environment Variables.
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://votre-domaine.fr

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

RESEND_API_KEY=
FROM_EMAIL=
ADMIN_EMAIL=

MONDIAL_RELAY_ENSEIGNE=
MONDIAL_RELAY_PRIVATE_KEY=
NEXT_PUBLIC_MONDIAL_RELAY_BRAND_ID=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

CRON_SECRET=

# Obligatoire en production — ne pas laisser à true
SHIPPING_DEV_MOCK=false
