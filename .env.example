# =============================================================================
# Tilouki — Variables d'environnement
# Copier vers .env.local (dev) ou configurer dans Vercel (production).
# Ne jamais committer de secrets.
#
# Vérification locale :
#   npm run verify:deploy          (dev)
#   npm run verify:deploy:prod     (règles production)
# Documentation :
#   docs/variables-production.md   (référence complète des variables prod)
#   docs/guide-test-production.md    (test réel petit montant)
#   docs/deploiement-vercel.md     (déploiement Vercel)
# =============================================================================

# --- Analytics (optionnel — chargé uniquement après consentement cookies) ---
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tilouki.fr

# --- Application ---
# Dev : http://localhost:3000
# Prod : https://tilouki.fr (ou votre domaine — HTTPS obligatoire)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optionnel — surcharge affichage boutique
# NEXT_PUBLIC_SHOP_NAME=Tilouki
# NEXT_PUBLIC_SHOP_PRIMARY_COLOR=oklch(0.62 0.12 30)
# NEXT_PUBLIC_SHOP_CONTACT_EMAIL=contact@tilouki.fr

# --- Supabase (obligatoire) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (obligatoire pour les paiements) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- E-mails transactionnels (Resend recommandé) ---
RESEND_API_KEY=
FROM_EMAIL=commandes@tilouki.fr
ADMIN_EMAIL=contact@tilouki.fr

# Alternative SMTP si RESEND_API_KEY absent :
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false

# Anciennes variables encore supportées : EMAIL_FROM, ADMIN_NOTIFICATION_EMAIL

# --- Mondial Relay (obligatoire en production) ---
# Code enseigne / brand ID (les deux noms sont acceptés)
MONDIAL_RELAY_ENSEIGNE=
# MONDIAL_RELAY_BRAND_ID=   # alias de MONDIAL_RELAY_ENSEIGNE
MONDIAL_RELAY_PRIVATE_KEY=
NEXT_PUBLIC_MONDIAL_RELAY_BRAND_ID=
NEXT_PUBLIC_MONDIAL_RELAY_PARCEL_SIZE=M

# --- Chronopost relais / Shop2Shop (optionnel) ---
# Si absent, le site fonctionne en mono-transporteur Mondial Relay.
# Numéro de contrat (8 chiffres) + mot de passe associé.
CHRONOPOST_ACCOUNT_NUMBER=
CHRONOPOST_PASSWORD=
# Cotation via l'API QuickCost au lieu du barème DB (cache mémoire 10 min,
# fallback barème DB si l'API échoue). Par défaut : barème DB.
# CHRONOPOST_USE_QUICKCOST=true
# Code postal de départ pour QuickCost (adresse boutique) — défaut 75001.
# CHRONOPOST_DEPARTURE_ZIP=

# Dev uniquement — mock points relais si aucun transporteur configuré.
# PRODUCTION : ne pas définir cette variable, ou mettre false explicitement.
SHIPPING_DEV_MOCK=true

# --- CSP — rapport de violations (optionnel) ---
# URL d'un collecteur de rapports CSP (ex. report-uri.com). Si absent, aucun
# rapport n'est émis (les directives report-uri / report-to sont omises).
# CSP_REPORT_URI=https://example.report-uri.com/r/d/csp/enforce

# --- Rate limiting Upstash Redis (production — fortement recommandé) ---
# Sans ces variables, la limitation de débit repose sur une Map en mémoire :
# fonctionnel en dev local, inopérant sur Vercel serverless (instances multiples).
# Base gratuite : https://console.upstash.com → Redis → région eu (voir docs/deploiement-vercel.md)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron Vercel (production — obligatoire) ---
# Secret pour /api/cron/expire-pending-orders (libération stock commandes pending expirées)
CRON_SECRET=
