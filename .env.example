# =============================================================================
# Tilouki — Variables d'environnement
# Copier vers .env.local (dev) ou configurer dans Vercel (production).
# Ne jamais committer de secrets — laisser les valeurs vides ou des placeholders.
#
# Vérification :
#   npm run verify:deploy          (dev / .env.local)
#   npm run verify:deploy:prod     (garde-fou avant vente — toutes les variables ci-dessous)
#
# Documentation :
#   docs/variables-production.md      (référence complète)
#   docs/PRODUCTION_CHECKLIST.md      (contrôles alignés sur verify:deploy:prod)
#   docs/deploiement-vercel.md
#   docs/guide-test-production.md
# =============================================================================

# --- Analytics (optionnel — chargé uniquement après consentement cookies) ---
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tilouki.fr
# Goals custom : add_to_cart, begin_checkout, add_capsule_to_cart (à déclarer dans Plausible)

# --- Merchandising (optionnel) ---
# Seuil livraison relais offerte en centimes TTC (défaut 8000 = 80 €). Mettre "off" pour masquer la jauge.
# NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD_CENTS=8000

# --- Remise tenue Tilouki (optionnel) ---
# RITUAL_BUNDLE_MIN_ITEMS=4
# RITUAL_BUNDLE_DISCOUNT_PERCENT=5

# --- Application (obligatoire) ---
# Dev : http://localhost:3000
# Prod : https://votre-domaine.fr — HTTPS obligatoire (verify:deploy:prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optionnel — surcharge affichage boutique
# NEXT_PUBLIC_SHOP_NAME=Tilouki
# NEXT_PUBLIC_SHOP_PRIMARY_COLOR=oklch(0.58 0.18 15)
# NEXT_PUBLIC_SHOP_CONTACT_EMAIL=contact@tilouki.fr

# --- Supabase (obligatoire) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe mode Live en production (obligatoire pour encaisser) ---
# Dev : sk_test_ / pk_test_ — Prod : sk_live_ / pk_live_ (les deux doivent correspondre)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- E-mails transactionnels (obligatoire en production) ---
# Resend recommandé — ou SMTP_HOST + SMTP_USER + SMTP_PASSWORD
RESEND_API_KEY=
FROM_EMAIL=
ADMIN_EMAIL=

# Dev uniquement — redirige tous les envois vers votre boîte de test
# EMAIL_DEV_REDIRECT=votre.email@example.com
# Dev uniquement — écrit aussi les e-mails dans .email-preview/ (npm run email:preview)
# EMAIL_PREVIEW_WRITE=true
# Aperçu navigateur : http://localhost:3000/dev/emails

# Alternative SMTP si RESEND_API_KEY absent :
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false

# Anciennes variables encore supportées : EMAIL_FROM, ADMIN_NOTIFICATION_EMAIL

# --- Newsletter Brevo (optionnel — double opt-in stocké en base même sans Brevo) ---
# BREVO_API_KEY=
# BREVO_LIST_ID=

# --- Mondial Relay (obligatoire en production) ---
MONDIAL_RELAY_ENSEIGNE=
# MONDIAL_RELAY_BRAND_ID=   # alias de MONDIAL_RELAY_ENSEIGNE
MONDIAL_RELAY_PRIVATE_KEY=
NEXT_PUBLIC_MONDIAL_RELAY_BRAND_ID=
NEXT_PUBLIC_MONDIAL_RELAY_PARCEL_SIZE=M

# --- Chronopost relais / Shop2Shop (optionnel) ---
# Si absent, le site fonctionne en mono-transporteur Mondial Relay.
CHRONOPOST_ACCOUNT_NUMBER=
CHRONOPOST_PASSWORD=
# CHRONOPOST_USE_QUICKCOST=true
# CHRONOPOST_DEPARTURE_ZIP=

# Dev uniquement — mock points relais si aucun transporteur configuré.
# PRODUCTION : ne pas définir, ou SHIPPING_DEV_MOCK=false (verify:deploy:prod échoue si true)
SHIPPING_DEV_MOCK=true

# --- CSP — rapport de violations (optionnel) ---
# CSP_REPORT_URI=

# --- Rate limiting Upstash Redis (obligatoire en production) ---
# Sans Upstash, les routes sensibles répondent 503 en production (pas de fallback mémoire).
# Console : https://console.upstash.com → Redis → région EU → onglet REST API
#   UPSTASH_REDIS_REST_URL=https://….upstash.io
#   UPSTASH_REDIS_REST_TOKEN=…
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron Vercel (obligatoire en production) ---
# Secret Bearer pour /api/cron/expire-pending-orders (32+ caractères)
CRON_SECRET=
