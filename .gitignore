# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# env files — jamais versionner (modèle public : .env.example uniquement)
.env*
!.env.example
!.env.production.local.example

# archives manuelles à la racine (zip/rar du dossier entier — interdit)
/*.zip
/*.rar

# vercel (lien projet + variables locales)
.vercel
.vercel/
.env.vercel
.vercel/.env*.local

# supabase cli temp
supabase/.temp/

# archives de livraison locales (npm run archive:clean)
/archives/

# caches & artefacts locaux
.turbo/
.cache/
dist/
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

# exports preview e-mails (npm run email:preview)
.email-preview/

# rapports Lighthouse / audits locaux
lighthouse*.html
lighthouse*.json
.eslintcache

# captures locales & exports temporaires (QA, recette, admin)
/screenshots/
/captures/
/exports/
/export/
/temp/
/tmp/
