{
  "name": "tilouki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:secrets": "node scripts/audit-secrets.mjs",
    "delivery:clean": "node scripts/prepare-archive.mjs",
    "delivery:release": "npm run audit:secrets && npm run delivery:clean && node scripts/verify-archive.mjs --latest",
    "archive:clean": "npm run delivery:clean",
    "verify:archive": "node scripts/verify-archive.mjs",
    "scan:deliverable": "node scripts/scan-deliverable.mjs",
    "prepare:archive": "npm run delivery:clean",
    "seed:dev": "node scripts/seed-dev.mjs",
    "seed:catalog": "node scripts/seed-catalog.mjs",
    "catalog:go-live": "node scripts/go-live-catalog.mjs",
    "generate:catalog": "node scripts/generate-catalog.mjs",
    "generate:demo-images": "node scripts/generate-demo-images.mjs",
    "check": "npm run audit:secrets && npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "fonts:fetch": "node scripts/fetch-fonts.mjs",
    "editorial:fetch": "node scripts/fetch-editorial-images.mjs",
    "e2e": "node scripts/run-playwright.mjs",
    "e2e:journey": "node scripts/run-playwright.mjs e2e/sales-journey.spec.ts",
    "e2e:battle-plan": "node scripts/run-playwright.mjs e2e/battle-plan-features.spec.ts",
    "e2e:tracking": "node scripts/run-playwright.mjs e2e/order-tracking.spec.ts",
    "e2e:visual-qa": "node scripts/run-playwright.mjs e2e/visual-qa-retail.spec.ts",
    "lighthouse:mobile": "node scripts/lighthouse-perf-budget.mjs",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "qa": "npm run typecheck && npm run lint && npm run test && npm run build && node scripts/run-e2e.mjs",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "verify:deploy:prod": "node scripts/verify-deploy.mjs --production",
    "go-live:preflight": "node scripts/go-live-preflight.mjs",
    "go-live:audit": "node scripts/go-live-audit.mjs",
    "email:preview": "node scripts/preview-emails.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.78.0",
    "sanitize-html": "^2.17.5",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
